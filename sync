#!/usr/bin/env bash
# Quick entry point — run from anywhere
# Usage: ./sync repos | ./sync pull | ./sync status | ./sync export | ./sync import | ./sync team-export | ./sync team-import | ./sync setup

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)/scripts"

case "${1:-help}" in
    repos)    shift; bash "$SCRIPT_DIR/sync-repos.sh" "$@" ;;
    pull)     shift; bash "$SCRIPT_DIR/sync-repos.sh" --pull-only "$@" ;;
    status)   bash "$SCRIPT_DIR/sync-repos.sh" --status ;;
    export)      shift; bash "$SCRIPT_DIR/sync-claude.sh" export "$@" ;;
    import)      shift; bash "$SCRIPT_DIR/sync-claude.sh" import "$@" ;;
    install)     shift; bash "$SCRIPT_DIR/sync-claude.sh" install "$@" ;;
    team-export) shift; bash "$SCRIPT_DIR/sync-claude.sh" team-export "$@" ;;
    team-import) shift; bash "$SCRIPT_DIR/sync-claude.sh" team-import "$@" ;;
    setup)    bash "$SCRIPT_DIR/setup-device.sh" ;;
    manifest) bash "$SCRIPT_DIR/update-manifest.sh" ;;
    # Codex sync commands
    codex-export)  shift; bash "$SCRIPT_DIR/sync-codex.sh" export "$@" ;;
    codex-import)  shift; bash "$SCRIPT_DIR/sync-codex.sh" import "$@" ;;
    codex-install) shift; bash "$SCRIPT_DIR/sync-codex.sh" install "$@" ;;
    help|*)
        echo "dev-sync — Multi-device development environment sync"
        echo ""
        echo "Usage: ./sync <command> [options]"
        echo ""
        echo "Commands:"
        echo "  repos          Clone missing repos, pull existing ones"
        echo "  pull           Pull latest changes on all cloned repos (skip missing)"
        echo "  status         Show status of all repos (dirty, ahead/behind)"
        echo "  export         Export Claude Code config to this repo"
        echo "  import         Import Claude Code config to this device"
        echo "  install        Install Claude skills, rules, and settings (symlink)"
        echo "  team-export    Export shareable config (skills, rules, plugins, MCP) for team"
        echo "  team-import    Import shared team config (skills, rules, plugins, MCP only)"
        echo "  setup          Full device bootstrap (first time on new device)"
        echo "  manifest       Re-scan ~/Projects and update repos.manifest"
        echo ""
        echo "Codex Commands:"
        echo "  codex-export   Export Codex config to this repo"
        echo "  codex-import   Import Codex config to this device"
        echo "  codex-install  Install Codex skills (AGENTS.md files)"
        echo ""
        echo "Options (for export/import commands):"
        echo "  -n, --dry-run  Show what would be done"
        echo ""
        echo "Examples:"
        echo "  ./sync pull                     # Pull all cloned repos"
        echo "  ./sync pull -f SEMCL            # Pull only SEMCL.ONE repos"
        echo "  ./sync repos                    # Sync all repos"
        echo "  ./sync repos -f SEMCL           # Sync only SEMCL.ONE repos"
        echo "  ./sync repos -n                 # Dry run"
        echo "  ./sync status                   # Check what's dirty/behind"
        echo "  ./sync export                   # Export all Claude config"
        echo "  ./sync export -n                # Dry run export"
        echo "  ./sync install                  # Install Claude skills (symlink)"
        echo "  ./sync install --copy           # Copy instead of symlink"
        echo "  ./sync team-export              # Export shareable team config"
        echo "  ./sync team-import -n           # Preview team import"
        echo "  ./sync codex-install            # Install Codex skills"
        echo "  ./sync codex-install --copy     # Copy instead of symlink"
        ;;
esac
